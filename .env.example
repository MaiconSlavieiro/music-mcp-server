# ─── Server ───
PORT=18960
BASE_URL=http://127.0.0.1:18960
# BASE_URL=https://music-mcp-server.yourdomain.com

# ─── Web Interface Auth (Basic Auth) ───
WEB_USERNAME=admin
WEB_PASSWORD=change-me

# ─── MCP Endpoint Auth (Bearer Token) ───
MCP_AUTH_TOKEN=change-me-to-a-random-secret

# ─── Spotify ───
# Get these from https://developer.spotify.com/dashboard
# Set Redirect URI to: ${BASE_URL}/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Genius ───
# Get this from https://genius.com/api-clients → Generate Access Token
GENIUS_ACCESS_TOKEN=
